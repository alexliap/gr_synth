# vLLM endpoint (already deployed)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL_ID=ilsp/Llama-Krikri-8B-Instruct

# Hugging Face Hub
HF_TOKEN=
HF_REPO_ID=your-org/greek-synth-v1

# Sampling (guide §6)
TEMPERATURE=0.7
TOP_P=0.95
MAX_TOKENS=2048
REPETITION_PENALTY=1.05

# Pipeline
CONCURRENCY=64
# 5 GiB filtered text → one shard / Hub push
SHARD_BYTES=5368709120
LOCAL_SHARD_DIR=./data/shards

# Source dataset
SOURCE_NAME=alexliap/high-quality-gr-text
# One of: fineweb_hq_el (4.35M rows), finepdfs_el (209k), finewiki_el (243k), wikipedia_el (235k)
SOURCE_CONFIG=fineweb_hq_el
SOURCE_SPLIT=train
MAX_INPUT_CHARS=12000

# Output filters
LID_MODEL_PATH=./models/lid.176.bin
LID_THRESHOLD=0.9
MIN_OUTPUT_CHARS=150
MAX_OUTPUT_CHARS=8000
MINHASH_THRESHOLD=0.8
MINHASH_PERM=128
